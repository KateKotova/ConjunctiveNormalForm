#z@x ( P(x) > @y ( P(y) > P(z) ) * ~@y ( Q(x,y) > P(y) ) ) ==
#z@x ( ~P(x) + ( @y ( ~P(y) + P(z) ) * ~@y ( ~Q(x,y) + P(y) ) ) ) ==
#z@x ( ~P(x) + ( @y ( ~P(y) + P(z) ) * #y ~( ~Q(x,y) + P(y) ) ) ) ==
#z@x ( ~P(x) + ( @y ( ~P(y) + P(z) ) * #y ( Q(x,y) * ~P(y) ) ) ) ==
#z@x ( ~P(x) + ( @y ( ~P(y) + P(z) ) * #a ( Q(x,a) * ~P(a) ) ) ) ==
@x ( ~P(x) + ( @y ( ~P(y) + P(A) ) * #a ( Q(x,a) * ~P(a) ) ) ) ==
@x ( ~P(x) + ( @y ( ~P(y) + P(A) ) * ( Q(x,b(x)) * ~P(b(x)) ) ) ) ==
@x@y ( ~P(x) + ( ( ~P(y) + P(A) ) * Q(x,b(x)) * ~P(b(x)) ) ) ==
@x@y ( ( ~P(x) + ~P(y) + P(A) ) * ( ~P(x) + Q(x,b(x)) ) * ( ~P(x) + ~P(b(x)) ) ) ==
{ ( ~P(x) + ~P(y) + P(A) ) , ( ~P(x) + Q(x,b(x)) ) , ( ~P(x) + ~P(b(x)) ) } ==
{ ( ~P(x) + ~P(y) + P(A) ) , ( ~P(x1) + Q(x1,b(x1)) ) , ( ~P(x2) + ~P(b(x2)) ) }